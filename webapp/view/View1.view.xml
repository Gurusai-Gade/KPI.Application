<mvc:View
    controllerName="app.kpi.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="15 Minutes Notification KPI">

        <content>

            <Toolbar>
                <Title text="15 Minutes Notification KPI" />

                <ToolbarSpacer />

                <Button
                    text="Export to Excel"
                    icon="sap-icon://excel-attachment"
                    type="Emphasized"
                    press=".onExportExcel" />
            </Toolbar>

            <ScrollContainer
                horizontal="true"
                vertical="true"
                height="100%"
                width="100%">

                <Table
                    id="kpiTable"
                    items="{kpi>/NotificationKPIData}"
                    growing="true"
                    fixedLayout="false">

                    <columns>

                        <Column width="80px">
                            <Text text="Sl.No"/>
                        </Column>

                        <Column width="250px">
                            <Text text="Install Base Item"/>
                        </Column>

                        <Column width="180px">
                            <Text text="Alert Based Incident/Case"/>
                        </Column>

                        <Column width="150px">
                            <Text text="Alert Category"/>
                        </Column>

                        <Column width="120px">
                            <Text text="Business Type"/>
                        </Column>

                        <Column width="150px">
                            <Text text="Disruption / Degradation"/>
                        </Column>

                        <Column width="120px">
                            <Text text="Event ID"/>
                        </Column>

                        <Column width="250px">
                            <Text text="Event/Outage Start Time"/>
                        </Column>

                        <Column width="250px">
                            <Text text="Event Trigger Time"/>
                        </Column>

                        <Column width="120px">
                            <Text text="Time Diff"/>
                        </Column>

                        <Column width="250px">
                            <Text text="Remarks"/>
                        </Column>

                    </columns>

                    <items>

                        <ColumnListItem>

                            <cells>

                                <Text text="{kpi>SlNo}" />

                                <Input
                                    value="{kpi>InstallBaseItem}"
                                    width="150px"
                                    liveChange=".onCIDCheck"
                                    maxLength="6"
                                    placeholder="Enter CID" />

                                <Input
                                    value="{kpi>AlertBasedIncidentCase}"
                                    width="150px"
                                    liveChange=".onCIDCheck"
                                    maxLength="12"
                                    placeholder="Enter Number">

                                    <core:Item
                                        key="Incident"
                                        text="Incident"/>

                                    <core:Item
                                        key="Case"
                                        text="Case"/>

                                </Input>

                                <ComboBox
                                    selectedKey="{kpi>AlertCategory}"
                                    width="150px">

                                    <!-- <core:Item
                                        key="Incident"
                                        text="Incident"/> -->

                                    <core:Item
                                        key="Case"
                                        text="Case"/>

                                    <core:Item
                                        key="Promothies"
                                        text="Promothies"/>
                                    <core:Item
                                        key="Availability"
                                        text="Availability"/>

                                </ComboBox>

                                <ComboBox
                                    selectedKey="{kpi>BusinessType}"
                                    items="{kpi>/BusinessTypeDropdown}"
                                    width="120px">

                                    <core:Item
                                        key="{kpi>key}"
                                        text="{kpi>text}" />

                                </ComboBox>

                                <ComboBox
                                    selectedKey="{kpi>DisruptionDegradation}"
                                    width="150px">

                                    <core:Item
                                        key="Disruption"
                                        text="Disruption"/>

                                    <core:Item
                                        key="Degradation"
                                        text="Degradation"/>

                                </ComboBox>

                                <Input
                                    value="{kpi>EventID}"
                                    width="120px" />

                                <Input
                                    value="{kpi>EventOutageStartTime}"
                                    width="250px"
                                    placeholder="MM/DD/YYYY HH:mm:ss"
                                    change=".onCalculateTimeDiff" />

                                <Input
                                    value="{kpi>EventTriggerTime}"
                                    width="250px"
                                    placeholder="MM/DD/YYYY HH:mm:ss"
                                    change=".onCalculateTimeDiff" />

                                <Text text="{kpi>TimeDiff}" />

                                <VBox>
                                    <Button
                                        text="Remarks"
                                        icon="sap-icon://edit"
                                        type="Emphasized"
                                        press=".onOpenRemarksDialog" />

                                    <Text
                                        text="{kpi>Remarks}"
                                        width="200px"
                                        wrapping="true" />
                                </VBox>

                            </cells>

                        </ColumnListItem>

                    </items>

                </Table>

            </ScrollContainer>

        </content>

    </Page>

</mvc:View>